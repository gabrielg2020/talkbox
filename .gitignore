# Generated recordings: audio + metadata sidecars (keep the folder, ignore contents)
recordings/*
!recordings/.gitkeep
# also ignore any strays outside the folder
*.mp3
*.wav
*.talkbox.json

# Persisted settings
config.json

# Input text files (keep the folder, ignore its contents)
source/*
!source/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# macOS
.DS_Store

# Editors
.vscode/
.idea/
